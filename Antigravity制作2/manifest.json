{
    "manifest_version": 3,
    "name": "Free Media Search",
    "version": "1.0.0",
    "description": "Search free images and videos from Pexels & Pixabay",
    "permissions": [
        "downloads",
        "storage"
    ],
    "host_permissions": [
        "https://api.pexels.com/*",
        "https://pixabay.com/api/*",
        "https://images.pexels.com/*",
        "https://videos.pexels.com/*",
        "https://cdn.pixabay.com/*",
        "https://i.vimeocdn.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}